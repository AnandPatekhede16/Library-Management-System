# ─────────────────────────────────────────────────────────────────
#  .env.example — Environment Variables Template
#
#  Copy this file and fill in your actual values.
#  For LOCAL development: put values in application-local.properties
#  For DEPLOYMENT (Render/Railway): set these as Environment Variables
#                                   in your hosting platform dashboard.
#
#  ⚠️  NEVER commit a file with real passwords to GitHub!
# ─────────────────────────────────────────────────────────────────

# ── MySQL Database ────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/library_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# ── Gmail SMTP (for email notifications) ─────────────────────
# Use a Gmail App Password (NOT your real Gmail password)
# How to generate: myaccount.google.com → Security → App Passwords
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password_here

# ── Optional Settings (these have safe defaults) ─────────────
SERVER_PORT=8085
SOCKET_PORT=9090
FINE_PER_DAY=20
